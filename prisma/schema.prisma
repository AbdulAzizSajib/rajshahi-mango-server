generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  fullName String
  phone    String
  address  String
  city     String

  deliveryType DeliveryType
  deliveryDate DateTime

  notes String?

  subtotal Float
  total    Float

  status OrderStatus @default(pending)

  paymentMethod PaymentMethod
  transactionId String

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variety  String
  quantity Int
  price    Float

  @@map("order_items")
}

enum DeliveryType {
  courier
  home
}

enum PaymentMethod {
  bkash
  nagad
}

enum OrderStatus {
  pending
  confirmed
  processing
  packed
  shipped
  out_for_delivery
  delivered
  cancelled
  returned
  refunded
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("admins")
}

model Testimonial {
  id         String    @id @default(cuid())
  name       String
  comment    String
  location   String
  date       DateTime?
  isApproved Boolean   @default(false)
  isFeatured Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@map("testimonials")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String
  location     String
  regularprice Float
  offerPrice   Float?
  images       String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("products")
}

model HeroBanner {
  id         String   @id @default(cuid())
  title      String
  subtitle   String?
  category   String?
  harvestDate DateTime?
  images     String[]
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("hero_banners")
}
